defparam n385_s93.ALU_MODE=1;
  ALU n385_s94 (
    .SUM(n385_95_SUM),
    .COUT(n385_128),
    .I0(r_timer[30]),
    .I1(w_trst_ms[30]),
    .I3(GND),
    .CIN(n385_126) 
);
defparam n385_s94.ALU_MODE=1;
  ALU n385_s95 (
    .SUM(n385_96_SUM),
    .COUT(n385_130),
    .I0(r_timer[31]),
    .I1(w_trst_ms[31]),
    .I3(GND),
    .CIN(n385_128) 
);
defparam n385_s95.ALU_MODE=1;
  INV n87_s4 (
    .O(n87_9),
    .I(r_ms_cnt[0]) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* watchdog_core */
module watchdog_top (
  i_clk,
  i_rst_n,
  i_wdi,
  i_en,
  i_uart_rx,
  o_wdo,
  o_enout,
  o_uart_tx
)
;
input i_clk;
input i_rst_n;
input i_wdi;
input i_en;
input i_uart_rx;
output o_wdo;
output o_enout;
output o_uart_tx;
wire i_clk_d;
wire i_rst_n_d;
wire i_wdi_d;
wire i_en_d;
wire i_uart_rx_d;
wire w_kick_signal;
wire w_kick_negedge;
wire r_last_kick_src;
wire r_kick_d;
wire n11_6;
wire w_wdi_clean;
wire w_en_clean;
wire w_wr_en;
wire w_cmd_kick;
wire o_uart_tx_d;
wire w_uart_kick_p;
wire w_clr_fault;
wire n563_4;
wire n595_4;
wire n627_4;
wire n659_4;
wire n563_6;
wire w_fault_active;
wire n396_6;
wire [7:0] w_addr;
wire [31:0] w_wr_data;
wire [7:0] w_ctrl;
wire [31:0] w_twd_ms;
wire [31:0] w_trst_ms;
wire [15:0] w_arm_delay_us;
wire [1:0] r_state;
wire VCC;
wire GND;
  IBUF i_clk_ibuf (
    .O(i_clk_d),
    .I(i_clk) 
);
  IBUF i_rst_n_ibuf (
    .O(i_rst_n_d),
    .I(i_rst_n) 
);
  IBUF i_wdi_ibuf (
    .O(i_wdi_d),
    .I(i_wdi) 
);
  IBUF i_en_ibuf (
    .O(i_en_d),
    .I(i_en) 
);
  IBUF i_uart_rx_ibuf (
    .O(i_uart_rx_d),
    .I(i_uart_rx) 
);
  OBUF o_wdo_obuf (
    .O(o_wdo),
    .I(w_fault_active) 
);
  OBUF o_enout_obuf (
    .O(o_enout),
    .I(n396_6) 
);
  OBUF o_uart_tx_obuf (
    .O(o_uart_tx),
    .I(o_uart_tx_d) 
);
  LUT3 w_kick_signal_s0 (
    .F(w_kick_signal),
    .I0(w_uart_kick_p),
    .I1(w_wdi_clean),
    .I2(w_ctrl[1]) 
);
defparam w_kick_signal_s0.INIT=8'h5C;
  LUT4 w_kick_negedge_s2 (
    .F(w_kick_negedge),
    .I0(w_uart_kick_p),
    .I1(w_wdi_clean),
    .I2(w_ctrl[1]),
    .I3(r_kick_d) 
);
defparam w_kick_negedge_s2.INIT=16'hA300;
  DFFCE r_last_kick_src_s0 (
    .Q(r_last_kick_src),
    .D(w_ctrl[1]),
    .CLK(i_clk_d),
    .CE(w_kick_negedge),
    .CLEAR(n11_6) 
);
  DFFP r_kick_d_s0 (
    .Q(r_kick_d),
    .D(w_kick_signal),
    .CLK(i_clk_d),
    .PRESET(n11_6) 
);
  INV n11_s2 (
    .O(n11_6),
    .I(i_rst_n_d) 
);
  sync_debounce sync1 (
    .i_clk_d(i_clk_d),
    .n11_6(n11_6),
    .i_wdi_d(i_wdi_d),
    .w_wdi_clean(w_wdi_clean)
);
  sync_debounce_0 sync2 (
    .i_clk_d(i_clk_d),
    .n11_6(n11_6),
    .i_en_d(i_en_d),
    .w_en_clean(w_en_clean)
);
  uart uart1 (
    .i_clk_d(i_clk_d),
    .n11_6(n11_6),
    .i_uart_rx_d(i_uart_rx_d),
    .n627_4(n627_4),
    .w_en_clean(w_en_clean),
    .n563_4(n563_4),
    .n595_4(n595_4),
    .n659_4(n659_4),
    .r_last_kick_src(r_last_kick_src),
    .n563_6(n563_6),
    .w_trst_ms(w_trst_ms[7:0]),
    .w_ctrl_0(w_ctrl[0]),
    .w_ctrl_1(w_ctrl[1]),
    .w_ctrl_3(w_ctrl[3]),
    .w_ctrl_4(w_ctrl[4]),
    .w_ctrl_5(w_ctrl[5]),
    .w_ctrl_6(w_ctrl[6]),
    .w_ctrl_7(w_ctrl[7]),
    .w_twd_ms(w_twd_ms[7:0]),
    .w_arm_delay_us(w_arm_delay_us[7:0]),
    .r_state(r_state[1:0]),
    .w_wr_en(w_wr_en),
    .w_cmd_kick(w_cmd_kick),
    .o_uart_tx_d(o_uart_tx_d),
    .w_addr(w_addr[7:0]),
    .w_wr_data(w_wr_data[31:0])
);
  regfile reg1 (
    .i_clk_d(i_clk_d),
    .n11_6(n11_6),
    .w_cmd_kick(w_cmd_kick),
    .w_wr_en(w_wr_en),
    .w_wr_data(w_wr_data[31:0]),
    .w_addr(w_addr[7:0]),
    .w_uart_kick_p(w_uart_kick_p),
    .w_clr_fault(w_clr_fault),
    .n563_4(n563_4),
    .n595_4(n595_4),
    .n627_4(n627_4),
    .n659_4(n659_4),
    .n563_6(n563_6),
    .w_ctrl_0(w_ctrl[0]),
    .w_ctrl_1(w_ctrl[1]),
    .w_ctrl_3(w_ctrl[3]),
    .w_ctrl_4(w_ctrl[4]),
    .w_ctrl_5(w_ctrl[5]),
    .w_ctrl_6(w_ctrl[6]),
    .w_ctrl_7(w_ctrl[7]),
    .w_twd_ms(w_twd_ms[31:0]),
    .w_trst_ms(w_trst_ms[31:0]),
    .w_arm_delay_us(w_arm_delay_us[15:0])
);
  watchdog_core wdt1 (
    .i_clk_d(i_clk_d),
    .n11_6(n11_6),
    .w_kick_signal(w_kick_signal),
    .w_clr_fault(w_clr_fault),
    .w_en_clean(w_en_clean),
    .w_arm_delay_us(w_arm_delay_us[15:0]),
    .w_twd_ms(w_twd_ms[31:0]),
    .w_trst_ms(w_trst_ms[31:0]),
    .w_ctrl(w_ctrl[0]),
    .w_fault_active(w_fault_active),
    .n396_6(n396_6),
    .r_state(r_state[1:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* watchdog_top */
